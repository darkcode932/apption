rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function: check if user is logged in
    function isLoggedIn() {
      return request.auth != null;
    }
    
    // Helper function: check if request matches user's UID
    function isOwner(userId) {
      return isLoggedIn() && request.auth.uid == userId;
    }

    // Helper function: get user document data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper function: check if user is an admin or super admin
    function isAdmin() {
      return isLoggedIn() && (
        getUserData().role == 'admin' || 
        getUserData().role == 'super_admin'
      );
    }

    // Helper function: check if user is a super admin
    function isSuperAdmin() {
      return isLoggedIn() && getUserData().role == 'super_admin';
    }

    // 1. Users Collection Rules
    match /users/{userId} {
      allow read: if isLoggedIn();
      // Users cannot sign up directly as admins
      allow create: if isLoggedIn() && request.auth.uid == userId && (
        !request.resource.data.keys().contains('role') || request.resource.data.role == 'user'
      );
      // Only owner can update profile (except role), but Super Admin can update anything (including role)
      allow update: if (isOwner(userId) && (
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
      )) || isSuperAdmin();
      allow delete: if false;
    }

    // 2. Petitions Collection Rules
    match /petition/{petitionId} {
      allow read: if true;
      allow create: if isLoggedIn();
      // Creator or Admin can update status, description or moderation flags (like isFeatured)
      allow update: if isLoggedIn() && (
        request.resource.data.status == resource.data.status || 
        resource.data.createdBy == request.auth.uid ||
        isAdmin()
      );
      // Creator or Admin can delete petition
      allow delete: if isLoggedIn() && (resource.data.createdBy == request.auth.uid || isAdmin());

      // 3. Comments subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
        allow update: if isLoggedIn() && resource.data.userId == request.auth.uid;
        allow delete: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      }

      // 4. Timeline subcollection
      match /timeline/{eventId} {
        allow read: if true;
        // Only creator or verified official accounts can post updates
        allow create: if isLoggedIn() && (
          get(/databases/$(database)/documents/petition/$(petitionId)).data.createdBy == request.auth.uid ||
          getUserData().isVerified == true ||
          isAdmin()
        );
        allow update, delete: if isLoggedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
      }

      // 5. Signatures subcollection
      match /signatures/{signatureId} {
        allow read: if true;
        allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if false; // signatures cannot be updated/deleted
      }
    }

    // 6. Notifications Collection Rules
    match /notifications/{notificationId} {
      allow read, update, delete: if isLoggedIn() && resource.data.userId == request.auth.uid;
      allow create: if isLoggedIn();
    }

    // 7. Donations Collection Rules
    match /donations/{donationId} {
      allow read: if true;
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false; // donations cannot be modified
    }
  }
}
